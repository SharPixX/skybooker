# ── Database (PostgreSQL) ──────────────────────────────────
# Runtime connection used by the application.
# For Supabase, use the pooled connection string here.
# For Prisma Postgres, use the prisma+postgres / Accelerate URL here.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Direct TCP connection used for schema changes and Prisma CLI operations.
# For Supabase, use the direct connection string.
# For Prisma Postgres, use the direct db.prisma.io URL.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Examples:
# Supabase DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
# Prisma Postgres DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."
# Prisma Postgres DIRECT_URL="postgres://username:password@db.prisma.io:5432/postgres?sslmode=require"

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Authentication ─────────────────────────────────────────
# Secret for signing JWT tokens (change in production!)
JWT_SECRET=your-secret-key-change-me-in-production

# ── CORS (production only) ─────────────────────────────────
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
